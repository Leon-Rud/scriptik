<Window x:Class="Scriptik.Windows.UI.History.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Style="{StaticResource ModernWindow}"
        Title="History" Width="780" Height="540"
        MinWidth="550" MinHeight="350"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="0">
        <!-- Top accent bar — solid -->
        <Border Height="3" VerticalAlignment="Top" Panel.ZIndex="10" Background="#00C896"/>

        <Grid Margin="0,3,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="290" MinWidth="220"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*" MinWidth="250"/>
            </Grid.ColumnDefinitions>

            <!-- Left panel: search + list -->
            <DockPanel Grid.Column="0" Background="{StaticResource BgSecondaryBrush}">
                <!-- Search bar -->
                <Border DockPanel.Dock="Top" Margin="14,14,14,8"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        CornerRadius="8" Background="{StaticResource BgCardBrush}">
                    <Grid>
                        <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   VerticalAlignment="Center" Margin="12,0,0,0"
                                   IsHitTestVisible="False"/>
                        <TextBox x:Name="SearchBox" BorderThickness="0" Background="Transparent"
                                 Foreground="{StaticResource TextPrimaryBrush}"
                                 CaretBrush="{StaticResource AccentBrush}"
                                 Padding="34,9,10,9" FontFamily="{StaticResource DefaultFont}"
                                 TextChanged="SearchBox_TextChanged"/>
                        <TextBlock x:Name="SearchPlaceholder" Text="Search transcriptions..."
                                   FontFamily="{StaticResource DefaultFont}" FontSize="13"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   VerticalAlignment="Center" Margin="34,0,0,0"
                                   IsHitTestVisible="False"/>
                    </Grid>
                </Border>

                <ListBox x:Name="EntryList" Margin="8,0,8,8"
                         BorderThickness="0" Background="Transparent"
                         Foreground="{StaticResource TextPrimaryBrush}"
                         SelectionChanged="EntryList_SelectionChanged">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="12,10"/>
                            <Setter Property="Margin" Value="0,1"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Bd" Padding="{TemplateBinding Padding}"
                                                CornerRadius="8" Background="Transparent"
                                                BorderThickness="0,0,2,0" BorderBrush="Transparent">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource BgCardBrush}"/>
                                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#EBEDF0"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding Date, StringFormat='{}{0:d}'}"
                                           FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                                           FontFamily="{StaticResource MonoFont}"/>
                                <TextBlock Text="{Binding Preview}" TextTrimming="CharacterEllipsis"
                                           MaxHeight="36" FontSize="13"
                                           FontFamily="{StaticResource DefaultFont}"
                                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,3"/>
                                <TextBlock Text="{Binding Date, StringFormat='{}{0:t}'}"
                                           FontSize="10" Foreground="{StaticResource TextMutedBrush}"
                                           FontFamily="{StaticResource MonoFont}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Copy" Click="CopyEntry_Click"/>
                            <MenuItem Header="Delete" Click="DeleteEntry_Click"/>
                        </ContextMenu>
                    </ListBox.ContextMenu>
                </ListBox>
            </DockPanel>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="1" HorizontalAlignment="Center"
                          VerticalAlignment="Stretch" Background="{StaticResource BorderBrush}"/>

            <!-- Right panel: detail -->
            <Grid Grid.Column="2" Background="{StaticResource BgPrimaryBrush}">
                <!-- Empty state -->
                <StackPanel x:Name="EmptyState" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Border Width="60" Height="60" CornerRadius="16"
                            Background="{StaticResource BgSecondaryBrush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                            HorizontalAlignment="Center" Margin="0,0,0,14">
                        <TextBlock Text="&#xE8C1;" FontFamily="Segoe MDL2 Assets" FontSize="26"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Select a transcription" Style="{StaticResource SectionHeader}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Choose from the list to view its contents."
                               Style="{StaticResource Subtitle}" HorizontalAlignment="Center"
                               Margin="0,6,0,0"/>
                </StackPanel>

                <!-- Detail view -->
                <DockPanel x:Name="DetailPanel" Visibility="Collapsed" Margin="18">
                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,14">
                        <Button x:Name="CopyButton" DockPanel.Dock="Right" Content="Copy"
                                Style="{StaticResource AccentButton}"
                                Click="CopyDetail_Click"/>
                        <TextBlock x:Name="DetailDate" Style="{StaticResource SectionHeader}"
                                   VerticalAlignment="Center"/>
                    </DockPanel>

                    <Border DockPanel.Dock="Top" Height="1"
                            Background="{StaticResource BorderBrush}" Margin="0,0,0,14"/>

                    <Border CornerRadius="10" Background="{StaticResource BgCardBrush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                            Padding="14">
                        <TextBox x:Name="DetailContent" IsReadOnly="True" TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto" BorderThickness="0"
                                 FontFamily="{StaticResource MonoFont}" FontSize="12.5"
                                 Foreground="{StaticResource TextPrimaryBrush}"
                                 Background="Transparent"
                                 CaretBrush="{StaticResource AccentBrush}"/>
                    </Border>
                </DockPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>
