<Window x:Class="Scriptik.Windows.UI.Settings.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:Scriptik.Windows.Converters"
        Style="{StaticResource ModernWindow}"
        Title="Scriptik Settings" Width="480" Height="540"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid>
        <!-- Top accent bar — solid -->
        <Border Height="3" VerticalAlignment="Top" Background="#00C896"/>

        <TabControl Style="{StaticResource ModernTabControl}" Margin="0,6,0,0">
            <TabControl.Resources>
                <Style TargetType="TabItem" BasedOn="{StaticResource ModernTabItem}"/>
            </TabControl.Resources>

            <!-- General Tab -->
            <TabItem Header="General">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20,16">
                    <StackPanel Margin="24,18">
                        <TextBlock Text="General" Style="{StaticResource SectionHeader}" Margin="0,0,0,4"/>
                        <TextBlock Text="Basic recording and behavior settings." Style="{StaticResource Subtitle}" Margin="0,0,0,20"/>

                        <CheckBox x:Name="LaunchAtLoginCheck" Content="Launch at login" Style="{StaticResource ModernCheckBox}"/>

                        <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                            <TextBlock Text="Language" VerticalAlignment="Center" Width="110"
                                       FontFamily="{StaticResource DefaultFont}"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <ComboBox x:Name="LanguageCombo" Width="200" Padding="10,7"
                                      Style="{StaticResource ModernComboBox}"/>
                        </StackPanel>

                        <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,18"/>

                        <CheckBox x:Name="FloatingCircleCheck" Content="Show floating circle button" Style="{StaticResource ModernCheckBox}"/>
                        <CheckBox x:Name="AutoPasteCheck" Content="Auto-paste after transcription" Style="{StaticResource ModernCheckBox}"/>
                        <CheckBox x:Name="TimestampsCheck" Content="Include timestamps in output" Style="{StaticResource ModernCheckBox}"/>
                        <CheckBox x:Name="SoundCheck" Content="Play sound feedback" Style="{StaticResource ModernCheckBox}"/>

                        <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,18"/>

                        <TextBlock Text="Initial prompt (hint words)" Margin="0,0,0,8"
                                   FontFamily="{StaticResource DefaultFont}" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBox x:Name="InitialPromptBox" Style="{StaticResource ModernTextBox}"
                                 AcceptsReturn="True" TextWrapping="Wrap" Height="60"/>

                        <StackPanel Margin="0,18,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Pause threshold" VerticalAlignment="Center" Width="110"
                                           FontFamily="{StaticResource DefaultFont}"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                <Slider x:Name="PauseSlider" Width="210" Minimum="0.5" Maximum="5.0"
                                        TickFrequency="0.1" IsSnapToTickEnabled="True"
                                        VerticalAlignment="Center"
                                        Style="{StaticResource ModernSlider}"/>
                                <Border Background="{StaticResource BgSecondaryBrush}" CornerRadius="5"
                                        Padding="8,3" Margin="10,0,0,0"
                                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                    <TextBlock x:Name="PauseLabel" Width="28" TextAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontFamily="{StaticResource MonoFont}"
                                               FontSize="12" Foreground="{StaticResource TextPrimaryBrush}"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Model Tab -->
            <TabItem Header="Model">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="24,18">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <Border Width="38" Height="38" CornerRadius="10"
                                    Background="{StaticResource AccentSubtleBrush}" Margin="0,0,14,0">
                                <TextBlock Text="&#xE950;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="18" Foreground="{StaticResource AccentBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Whisper Model" Style="{StaticResource SectionHeader}"/>
                                <TextBlock Text="Larger models are more accurate but slower."
                                           Style="{StaticResource Subtitle}"/>
                            </StackPanel>
                        </StackPanel>

                        <ListBox x:Name="ModelList" BorderThickness="0" Background="Transparent"
                                 Margin="0,14,0,0"
                                 SelectionChanged="ModelList_SelectionChanged">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="14,10"/>
                                    <Setter Property="Margin" Value="0,2"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="Bd" Padding="{TemplateBinding Padding}"
                                                        CornerRadius="8" Background="Transparent"
                                                        BorderThickness="0,0,3,0" BorderBrush="Transparent">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentSubtleBrush}"/>
                                                        <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="{StaticResource BgSecondaryBrush}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13"
                                                       FontFamily="{StaticResource DefaultFont}"
                                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                                            <Border Margin="10,0,0,0" Background="{StaticResource AccentSubtleBrush}"
                                                    CornerRadius="10" Padding="10,2"
                                                    Visibility="{Binding IsRecommended, Converter={StaticResource BoolToVis}}">
                                                <TextBlock Text="Recommended" FontSize="10"
                                                           Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold"/>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                                   Margin="0,3,0,0" FontFamily="{StaticResource DefaultFont}">
                                            <Run Text="{Binding Size}"/>  &#x2022;  <Run Text="{Binding Speed}"/>  &#x2022;  <Run Text="{Binding Accuracy}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Shortcut Tab -->
            <TabItem Header="Shortcut">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="24">
                    <Border Width="52" Height="52" CornerRadius="14"
                            Background="{StaticResource AccentSubtleBrush}"
                            HorizontalAlignment="Center" Margin="0,0,0,16">
                        <TextBlock Text="&#xE765;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="24" Foreground="{StaticResource AccentBrush}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <TextBlock Text="Global Shortcut" Style="{StaticResource SectionHeader}"
                               HorizontalAlignment="Center" Margin="0,0,0,6"/>
                    <TextBlock Text="Press your preferred key combination to toggle recording from any app."
                               Style="{StaticResource Subtitle}" TextAlignment="Center"
                               MaxWidth="300" Margin="0,0,0,24"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="Toggle Recording:" VerticalAlignment="Center" Margin="0,0,12,0"
                                   FontFamily="{StaticResource DefaultFont}"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                CornerRadius="7" Padding="0" MinWidth="160"
                                Background="{StaticResource BgCardBrush}">
                            <TextBox x:Name="ShortcutBox" BorderThickness="0" IsReadOnly="True"
                                     Background="Transparent" TextAlignment="Center"
                                     Padding="12,8"
                                     FontFamily="{StaticResource MonoFont}"
                                     Foreground="{StaticResource TextPrimaryBrush}"
                                     CaretBrush="{StaticResource AccentBrush}"
                                     Text="Press shortcut..."
                                     PreviewKeyDown="ShortcutBox_PreviewKeyDown"
                                     GotFocus="ShortcutBox_GotFocus"
                                     LostFocus="ShortcutBox_LostFocus"/>
                        </Border>
                        <Button x:Name="ClearShortcutBtn" Content="Clear" Margin="10,0,0,0"
                                Style="{StaticResource GhostButton}"
                                Click="ClearShortcut_Click"/>
                    </StackPanel>
                </StackPanel>
            </TabItem>

            <!-- Status Tab -->
            <TabItem Header="Status">
                <StackPanel Margin="24,18">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <Border Width="38" Height="38" CornerRadius="10"
                                Background="{StaticResource AccentSubtleBrush}" Margin="0,0,14,0">
                            <TextBlock Text="&#xE8D7;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="18" Foreground="{StaticResource AccentBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="System Status" Style="{StaticResource SectionHeader}"/>
                            <TextBlock Text="Check that everything is set up correctly."
                                       Style="{StaticResource Subtitle}"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Microphone -->
                    <Border Style="{StaticResource StatusBadge}" Margin="0,18,0,0"
                            x:Name="MicStatusBorder" Background="{StaticResource BgCardBrush}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="MicStatusIcon" FontFamily="Segoe MDL2 Assets"
                                       FontSize="18" VerticalAlignment="Center" Margin="0,0,14,0"/>
                            <StackPanel>
                                <TextBlock Text="Microphone" FontWeight="Medium"
                                           FontFamily="{StaticResource DefaultFont}"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock x:Name="MicStatusText" Style="{StaticResource Subtitle}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Python -->
                    <Border Style="{StaticResource StatusBadge}"
                            x:Name="PythonStatusBorder" Background="{StaticResource BgCardBrush}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="PythonStatusIcon" FontFamily="Segoe MDL2 Assets"
                                       FontSize="18" VerticalAlignment="Center" Margin="0,0,14,0"/>
                            <StackPanel>
                                <TextBlock Text="Python / Whisper" FontWeight="Medium"
                                           FontFamily="{StaticResource DefaultFont}"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock x:Name="PythonStatusText" Style="{StaticResource Subtitle}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Server -->
                    <Border Style="{StaticResource StatusBadge}"
                            x:Name="ServerStatusBorder" Background="{StaticResource BgCardBrush}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="ServerStatusIcon" FontFamily="Segoe MDL2 Assets"
                                       FontSize="18" VerticalAlignment="Center" Margin="0,0,14,0"/>
                            <StackPanel>
                                <TextBlock Text="Transcription Server" FontWeight="Medium"
                                           FontFamily="{StaticResource DefaultFont}"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock x:Name="ServerStatusText" Style="{StaticResource Subtitle}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Button Content="Open Sound Settings" Margin="0,22,0,0"
                            Style="{StaticResource ModernButton}"
                            HorizontalAlignment="Left" Click="OpenSoundSettings_Click"/>
                </StackPanel>
            </TabItem>

            <!-- About Tab -->
            <TabItem Header="About">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Border Width="68" Height="68" CornerRadius="18"
                            Background="{StaticResource AccentSubtleBrush}"
                            HorizontalAlignment="Center" Margin="0,0,0,16">
                        <TextBlock Text="&#xE720;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="30" Foreground="{StaticResource AccentBrush}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <TextBlock Text="Scriptik" FontSize="22" FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               FontFamily="{StaticResource DefaultFont}"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock x:Name="VersionText" FontSize="12"
                               Foreground="{StaticResource TextMutedBrush}"
                               HorizontalAlignment="Center" Margin="0,4,0,14"
                               FontFamily="{StaticResource MonoFont}"/>
                    <TextBlock Text="Voice-to-text with local Whisper transcription."
                               Style="{StaticResource Subtitle}" TextAlignment="Center"
                               Margin="0,0,0,14"/>
                    <TextBlock HorizontalAlignment="Center" FontFamily="{StaticResource DefaultFont}">
                        <Hyperlink x:Name="GitHubLink" Click="GitHubLink_Click"
                                   Foreground="{StaticResource AccentBrush}">GitHub</Hyperlink>
                    </TextBlock>
                </StackPanel>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
