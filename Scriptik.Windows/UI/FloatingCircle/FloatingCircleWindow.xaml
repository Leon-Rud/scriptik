<Window x:Class="Scriptik.Windows.UI.FloatingCircle.FloatingCircleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:Scriptik.Windows.Converters"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStyle="None"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Width="56" Height="56"
        Title="ScriptikFloatingCircle">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Solid, confident colors -->
        <SolidColorBrush x:Key="IdleBrush" Color="#1B1F23"/>
        <SolidColorBrush x:Key="RecordingBrush" Color="#E5322D"/>
        <SolidColorBrush x:Key="TranscribingBrush" Color="#00C896"/>
        <SolidColorBrush x:Key="CopiedBrush" Color="#22C55E"/>
    </Window.Resources>

    <Grid x:Name="RootGrid">
        <!-- Pulse ring 1 (recording only) -->
        <Ellipse x:Name="PulseRing1" Width="32" Height="32"
                 Stroke="#80E5322D" StrokeThickness="1.5"
                 HorizontalAlignment="Center" VerticalAlignment="Center"
                 Visibility="Collapsed" RenderTransformOrigin="0.5,0.5">
            <Ellipse.RenderTransform>
                <ScaleTransform x:Name="PulseScale1" ScaleX="1" ScaleY="1"/>
            </Ellipse.RenderTransform>
        </Ellipse>

        <!-- Pulse ring 2 (recording only) -->
        <Ellipse x:Name="PulseRing2" Width="32" Height="32"
                 Stroke="#4DE5322D" StrokeThickness="1.0"
                 HorizontalAlignment="Center" VerticalAlignment="Center"
                 Visibility="Collapsed" RenderTransformOrigin="0.5,0.5">
            <Ellipse.RenderTransform>
                <ScaleTransform x:Name="PulseScale2" ScaleX="1" ScaleY="1"/>
            </Ellipse.RenderTransform>
        </Ellipse>

        <!-- Main circle -->
        <Border x:Name="MainCircle" Width="32" Height="32" CornerRadius="16"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Background="{StaticResource IdleBrush}">
            <Border.Effect>
                <DropShadowEffect x:Name="CircleShadow" BlurRadius="6" ShadowDepth="2"
                                  Color="Black" Opacity="0.3"/>
            </Border.Effect>

            <Grid>
                <!-- Mic icon (idle) -->
                <TextBlock x:Name="MicIcon" Text="&#xE720;" FontFamily="Segoe MDL2 Assets"
                           FontSize="14" Foreground="White"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>

                <!-- Waveform bars (recording) -->
                <StackPanel x:Name="WaveformPanel" Orientation="Horizontal"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            Visibility="Collapsed">
                    <Rectangle x:Name="Bar0" Width="2" Height="4" Fill="White" Margin="0.75,0" RadiusX="1" RadiusY="1"/>
                    <Rectangle x:Name="Bar1" Width="2" Height="4" Fill="White" Margin="0.75,0" RadiusX="1" RadiusY="1"/>
                    <Rectangle x:Name="Bar2" Width="2" Height="4" Fill="White" Margin="0.75,0" RadiusX="1" RadiusY="1"/>
                    <Rectangle x:Name="Bar3" Width="2" Height="4" Fill="White" Margin="0.75,0" RadiusX="1" RadiusY="1"/>
                    <Rectangle x:Name="Bar4" Width="2" Height="4" Fill="White" Margin="0.75,0" RadiusX="1" RadiusY="1"/>
                </StackPanel>

                <!-- Transcribing indicator -->
                <TextBlock x:Name="TranscribingIcon" Text="&#xE712;" FontFamily="Segoe MDL2 Assets"
                           FontSize="14" Foreground="White"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Visibility="Collapsed"/>

                <!-- Checkmark (copied) -->
                <TextBlock x:Name="CheckIcon" Text="&#xE73E;" FontFamily="Segoe MDL2 Assets"
                           FontSize="14" Foreground="White"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Visibility="Collapsed"/>
            </Grid>
        </Border>

        <!-- Cancel button (recording only) -->
        <Border x:Name="CancelButton" Width="14" Height="14" CornerRadius="7"
                Background="#1B1F23" Cursor="Hand"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Margin="22,-22,0,0" Visibility="Collapsed"
                MouseLeftButtonDown="CancelButton_Click">
            <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets"
                       FontSize="7" Foreground="White"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>
    </Grid>
</Window>
